<Screens>
  <Screen model="GRP2601,GRP2602" width="132" height="48">

    <IdleScreen>
      <ShowStatusLine>true</ShowStatusLine>
      <DisplayElement>

        <!-- HORA -->
        <DisplayString font="time_14" width="48" height="12" halign="left" color="Black" bgcolor="White">
          <X>0</X>
          <Y>0</Y>
          <DisplayStr>$T</DisplayStr>
        </DisplayString>

        <!-- FECHA -->
        <DisplayString font="unifont" width="46" height="11" halign="right" color="Black" bgcolor="White">
          <X>50</X>
          <Y>1</Y>
          <DisplayStr>$Y/$o/$B</DisplayStr>
        </DisplayString>

        <!-- NOMBRE -->
        <DisplayString font="unifont" width="96" height="11" halign="left" color="Black" bgcolor="White">
          <X>0</X>
          <Y>13</Y>
          <DisplayStr>$p</DisplayStr>
        </DisplayString>

        <!-- EXTENSION -->
        <DisplayString font="unifont" width="96" height="11" halign="left" color="Black" bgcolor="White">
          <X>0</X>
          <Y>24</Y>
          <DisplayStr>Ext: $1</DisplayStr>
        </DisplayString>

