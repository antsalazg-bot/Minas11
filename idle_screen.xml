    <IdleScreen>
      <ShowStatusLine>true</ShowStatusLine>
      <DisplayElement>

        <!-- HORA izquierda -->
        <DisplayString font="time_14" width="50" height="13" halign="left" color="Black" bgcolor="White">
          <X>0</X>
          <Y>0</Y>
          <DisplayStr>$T</DisplayStr>
        </DisplayString>

        <!-- FECHA misma fila, a la derecha de la hora -->
        <DisplayString font="unifont" width="44" height="13" halign="right" color="Black" bgcolor="White">
          <X>50</X>
          <Y>2</Y>
          <DisplayStr>$Y/$o/$B</DisplayStr>
        </DisplayString>

        <!-- NOMBRE DE CUENTA -->
        <DisplayString font="unifont" width="93" height="11" halign="left" color="Black" bgcolor="White">
          <X>0</X>
          <Y>14</Y>
          <DisplayStr>$p</DisplayStr>
        </DisplayString>

        <!-- EXTENSION -->
        <DisplayString font="unifont" width="93" height="11" halign="left" color="Black" bgcolor="White">
          <X>0</X>
          <Y>25</Y>
          <DisplayStr>Ext: $1</DisplayStr>
        </DisplayString>

